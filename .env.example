# =============================================================
# COPY THIS FILE TO .env  (same folder as main.py)
# Then fill in your real values below.
# =============================================================

# ------------------------------------------------------------------
# STEP 1:  Your Atlassian login email
# ------------------------------------------------------------------
ATLASSIAN_EMAIL=your.email@example.com

# ------------------------------------------------------------------
# STEP 2:  API Token
# How to get it:
#   1. Open https://id.atlassian.com/manage-profile/security/api-tokens
#   2. Click "Create API token"
#   3. Name it anything (e.g. "LLM Project Manager")
#   4. Copy the token and paste it below
# ------------------------------------------------------------------
ATLASSIAN_API_TOKEN=your-api-token-here

# ------------------------------------------------------------------
# STEP 3:  Your Atlassian domain
# This is the URL you use to open Jira in your browser.
# Example: https://mycompany.atlassian.net
# DO NOT add a trailing slash.
# ------------------------------------------------------------------
ATLASSIAN_DOMAIN=https://yourcompany.atlassian.net

# ------------------------------------------------------------------
# STEP 4:  Your Jira project key
# This is the short code you see in issue IDs like MYPROJ-1
# Look in Jira: Project Settings > Details > Key
# ------------------------------------------------------------------
JIRA_PROJECT_KEY=MYPROJ

# ------------------------------------------------------------------
# STEP 5:  Project deadline (optional)
# Format: YYYY-MM-DD  (e.g. 2026-12-31)
# If left empty, defaults to 90 days from today.
# ------------------------------------------------------------------
JIRA_DEADLINE=2026-12-31

# ------------------------------------------------------------------
# STEP 6:  Hours per week each team member works (default 40)
# ------------------------------------------------------------------
JIRA_HOURS_PER_WEEK=40

# ------------------------------------------------------------------
# STEP 7:  Confluence Space Key (optional)
# Leave blank if you are not using Confluence.
# Find it in Confluence: Space Settings > Space Details > Key
# ------------------------------------------------------------------
CONFLUENCE_SPACE_KEY=
